<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Necesario en macOS para que getUserMedia pueda abrir la cámara
       (función de escanear listas en papel). Tauri fusiona este fichero
       con el Info.plist del bundle automáticamente. -->
  <key>NSCameraUsageDescription</key>
  <string>Garita usa la cámara para escanear listas de tareas en papel y añadirlas como to-dos.</string>
</dict>
</plist>
